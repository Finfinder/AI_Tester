{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI_Tester v2 - Model Ranking Report",
  "description": "Schema for model ranking output (0-100) per Decyzja 10 and Decyzja 13.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version, e.g. 2.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the benchmark"
    },
    "benchmark_config": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "judge_model": { "type": "string" },
        "tasks_count": { "type": "integer", "minimum": 0 },
        "total_time_seconds": { "type": "number", "minimum": 0 },
        "openrouter": {
          "type": "object",
          "description": "Aggregated redacted OpenRouter usage metadata.",
          "properties": {
            "provider": { "type": "string", "const": "openrouter" },
            "model": { "type": "string" },
            "judge_model": { "type": "string" },
            "total_input_tokens": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "total_output_tokens": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "total_tokens": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "total_estimated_cost_usd": {
              "type": ["number", "null"],
              "minimum": 0
            }
          },
          "required": ["provider", "model", "judge_model"]
        }
      },
      "required": ["model", "judge_model", "tasks_count"]
    },
    "ranking": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "judge_model": { "type": "string" },
        "scores": {
          "type": "object",
          "properties": {
            "plan": { "type": "integer", "minimum": 0, "maximum": 100 },
            "implementation": { "type": "integer", "minimum": 0, "maximum": 100 },
            "tools_and_terminal": { "type": "integer", "minimum": 0, "maximum": 100 },
            "overall": { "type": "integer", "minimum": 0, "maximum": 100 }
          },
          "required": ["plan", "implementation", "tools_and_terminal"]
        },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/definitions/taskResult" }
        }
      },
      "required": ["model", "scores", "tasks"]
    }
  },
  "required": ["version", "timestamp", "ranking"],
  "definitions": {
    "openrouterRequestMetadata": {
      "type": "object",
      "properties": {
        "request_id": { "type": ["string", "null"] },
        "role": { "type": "string", "enum": ["plan", "implement", "judge"] },
        "model": { "type": "string" },
        "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "input_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "output_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "total_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "role",
        "model",
        "status_code",
        "duration_seconds",
        "retry_count"
      ]
    },
    "taskResult": {
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "task_type": { "type": "string", "enum": ["feature", "refactor", "debug"] },
        "repo": { "type": "string" },
        "scores": {
          "type": "object",
          "properties": {
            "plan": { "type": "integer", "minimum": 0, "maximum": 100 },
            "implementation": { "type": "integer", "minimum": 0, "maximum": 100 },
            "tools_and_terminal": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        "time": {
          "type": "object",
          "properties": {
            "plan_seconds": { "type": "number", "minimum": 0 },
            "implement_seconds": { "type": "number", "minimum": 0 },
            "review_seconds": { "type": "number", "minimum": 0 }
          }
        },
        "details": { "type": "object" },
        "openrouter_requests": {
          "type": "array",
          "items": { "$ref": "#/definitions/openrouterRequestMetadata" }
        }
      },
      "required": ["task_id", "task_type", "repo"]
    }
  }
}
